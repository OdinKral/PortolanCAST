{
  "name": "portolancast",
  "version": "1.0.0",
  "description": "PortolanCAST — Plan Markup & Equipment Intelligence",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.portolancast.app",
    "productName": "PortolanCAST",
    "directories": { "output": "dist" },
    "extraResources": [
      { "from": "portolan-server", "to": "portolan-server" }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icons/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
